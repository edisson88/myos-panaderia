# ── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000

# ── Hasura ───────────────────────────────────────────────────────────────────
# URL completa del endpoint GraphQL de Hasura
HASURA_GRAPHQL_ENDPOINT=https://myospanaderia.hasura.app/v1/graphql

# Admin secret de Hasura (Hasura Console → Settings → Admin Secret)
HASURA_ADMIN_SECRET=Uwo35bNc51SqHiqZJFQ5m5xDU5PB6JqLD5nRK3aNcUpmFa41py3xt42jApyDXuwz

# JWT Secret en formato JSON de Hasura
# Debe coincidir exactamente con lo configurado en Hasura → Settings → JWT Config
# Ejemplo: {"type":"HS256","key":"tu-secreto-muy-largo-de-al-menos-32-caracteres"}
HASURA_GRAPHQL_JWT_SECRET={"type":"HS256","key":"23cbc82b6d80bbea114fd5f8605ee0c9457cc9706326d0d2ae04dfb0d43139ef"}

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_EXPIRES_IN=1d
DEFAULT_ROLE=user

# ── CORS ─────────────────────────────────────────────────────────────────────
# Separar múltiples orígenes por coma (sin espacios)
# ⚠ OBLIGATORIA en NODE_ENV=production
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
